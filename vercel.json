{
    "version": 2,
    "installCommand": "pnpm install",
    "buildCommand": "pnpm build",
    "outputDirectory": "dist/public",
    "rewrites": [
        {
            "source": "/api/(.*)",
            "destination": "/api/index.mjs"
        },
        {
            "source": "/(.*)",
            "destination": "/index.html"
        }
    ]
}